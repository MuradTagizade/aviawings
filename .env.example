# ——— Site ———
# Full production URL (used for SEO, sitemap, OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://aviawings.vercel.app

# ——— Business model ———
# "affiliate" (default): Select hands the traveller to a partner site with
# our marker; payment happens there, we earn commission. "internal": the
# old direct-booking flow (kept for a possible Duffel V2 switch).
NEXT_PUBLIC_SALES_MODE=affiliate
# Travelpayouts affiliate marker — sign up free at travelpayouts.com,
# individuals accepted (no company needed). Empty = links unattributed.
NEXT_PUBLIC_TP_MARKER=

# ——— Flights: Duffel (used for price display / internal mode) ———
# Free instant test mode: https://app.duffel.com/join
# Same API supports real ticketing later (Duffel is a consolidator).
# Leave empty to use the built-in realistic demo data.
DUFFEL_ACCESS_TOKEN=

# ——— Flights: Amadeus Self-Service (DEPRECATED) ———
# Portal shuts down 2026-07-17; new registrations are closed.
# Only fill these if you already have working keys.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ——— AI: OpenRouter (Gemini 2.5 Flash) ———
# https://openrouter.ai/keys — leave empty to show "coming soon" in the planner.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ——— Supabase (auth + database) ———
# https://supabase.com — create a free project, then run
# supabase/migrations/0001_init.sql in the SQL editor.
# Leave empty to hide all membership features gracefully.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ——— Analytics & Ads (loaded only after cookie consent) ———
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ——— Feature flags ———
# Set to "false" to hide the Hotels/eSIM coming-soon teaser
NEXT_PUBLIC_SHOW_COMING_SOON=true
